import dev.halim.shelfdroid.db.model.Episode;
import dev.halim.shelfdroid.network.libraryitem.BookChapter;
import kotlin.collections.List;

CREATE TABLE ItemEntity (
    id TEXT NOT NULL PRIMARY KEY,
    inoId TEXT NOT NULL,
    libraryId TEXT NOT NULL,
    author TEXT,
    title TEXT NOT NULL,
    cover TEXT,
    description TEXT,
    mediaType TEXT NOT NULL,
    chapters TEXT AS List<BookChapter> NOT NULL,
    episodes TEXT AS List<Episode> NOT NULL,
    FOREIGN KEY (libraryId) REFERENCES LibraryEntity(id) ON DELETE CASCADE
);

upsert:
INSERT OR REPLACE INTO ItemEntity (id, inoId, libraryId, author, title, cover, description, mediaType, chapters, episodes)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectById:
SELECT *
FROM ItemEntity
WHERE id = ?;

selectByLibraryId:
SELECT *
FROM ItemEntity
WHERE libraryId = ?;

selectAll:
SELECT *
FROM ItemEntity;

updateById:
UPDATE ItemEntity
SET
    inoId = ?,
    libraryId = ?,
    author = ?,
    title = ?,
    cover = ?,
    description = ?,
    mediaType = ?,
    chapters = ?,
    episodes = ?
WHERE id = ?;

removeAll:
DELETE FROM ItemEntity;

removeById:
DELETE FROM ItemEntity
WHERE id = ?;