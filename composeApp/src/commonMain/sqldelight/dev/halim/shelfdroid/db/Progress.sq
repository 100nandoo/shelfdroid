CREATE TABLE ProgressEntity (
    id TEXT NOT NULL PRIMARY KEY,
    itemId TEXT NOT NULL,
    progress REAL NOT NULL ,
    currentTime INTEGER NOT NULL,
    FOREIGN KEY (itemId) REFERENCES ItemEntity(id) ON DELETE CASCADE
);

upsert:
INSERT OR REPLACE INTO ProgressEntity (id, itemId, progress, currentTime)
VALUES (?, ?, ?, ?);

selectById:
SELECT *
FROM ProgressEntity
WHERE id = ?;

selectByItemId:
SELECT *
FROM ProgressEntity
WHERE itemId = ?;

selectAll:
SELECT *
FROM ProgressEntity;

updateById:
UPDATE ProgressEntity
SET
    itemId = ?,
    progress = ?,
    currentTime = ?
WHERE id = ?;

removeAll:
DELETE FROM ProgressEntity;

removeById:
DELETE FROM ProgressEntity
WHERE id = ?;